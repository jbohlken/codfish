# @name Netflix
# @description Netflix Timed Text Style Guide compliance
# @builtIn true

[formatting]
maxCharsPerLine = 42
maxCharsPerLine.strict = false
maxLines = 2
maxLines.strict = false

[timing]
minDuration = 20
minDuration.strict = false
minDuration.unit = fr
maxDuration = 7.0
maxDuration.strict = false
maxDuration.unit = s
maxCps = 20.0
maxCps.strict = false
extendToFill = true
extendToFillMax = 0.5
gapCloseThreshold = 0.5
minGapEnabled = true
minGapSeconds = 2
minGapSeconds.strict = true
minGapSeconds.unit = fr
defaultFps = 23.976

[merge]
enabled = true
phraseBreakGap = 0.7
minSegmentWords = 5
mergeGapThreshold = 0.5
